@* Platinum Brink Technologies Logo — uses the "Pb" SVG from platinum-brink.svg *@

<div class="d-flex align-center gap-3 unselectable @Class">
    <div class="position-relative @SvgClass flex-shrink-0 d-flex align-center justify-center">
        <img src="platinum-brink.svg" class="w-100 h-100" style="filter: drop-shadow(0 4px 10px rgba(0,51,102,0.12));" alt="Platinum Brink Logo" />
    </div>

    @if (!IconOnly)
    {
        <div class="d-flex flex-column text-left" style="line-height: 1.05;">
            <span class="@TitleClass font-sans font-weight-bold text-uppercase" style="letter-spacing: 0.03em;">
                PLATINUM BRINK
            </span>
            <span class="@SubtitleClass font-sans font-weight-bold text-uppercase" style="letter-spacing: 0.32em;">
                TECHNOLOGIES
            </span>
        </div>
    }
</div>

@code {
    [Parameter] public string Class { get; set; } = string.Empty;
    [Parameter] public bool IconOnly { get; set; } = false;
    [Parameter] public string Size { get; set; } = "md"; // "sm", "md", "lg"
    [Parameter] public string BorderColor { get; set; } = "navy";

    private string SvgClass => Size switch
    {
        "sm" => "logo-sm-svg",
        "lg" => "logo-lg-svg",
        _ => "logo-md-svg"
    };

    private string TitleClass => Size switch
    {
        "sm" => "logo-sm-title",
        "lg" => "logo-lg-title",
        _ => "logo-md-title"
    };

    private string SubtitleClass => Size switch
    {
        "sm" => "logo-sm-sub",
        "lg" => "logo-lg-sub",
        _ => "logo-md-sub"
    };
}

<style>
    .unselectable {
        user-select: none;
    }
    .logo-sm-svg { width: 32px; height: 32px; }
    .logo-sm-title { font-size: 1rem; color: var(--mud-palette-text-primary, #003366); font-weight: 800; }
    .logo-sm-sub { font-size: 6px; color: var(--mud-palette-text-secondary, rgba(0,51,102,0.7)); font-weight: 700; margin-top: -2px; }

    .logo-md-svg { width: 44px; height: 44px; }
    .logo-md-title { font-size: 1.125rem; color: var(--mud-palette-text-primary, #003366); font-weight: 800; }
    .logo-md-sub { font-size: 7.5px; color: var(--mud-palette-text-secondary, rgba(0,51,102,0.8)); font-weight: 700; margin-top: -2px; }

    .logo-lg-svg { width: 96px; height: 96px; }
    .logo-lg-title { font-size: 2.25rem; color: var(--mud-palette-text-primary, #003366); font-weight: 900; }
    .logo-lg-sub { font-size: 11px; color: var(--mud-palette-text-secondary, rgba(0,51,102,0.9)); font-weight: 800; margin-top: -4px; }
</style>
