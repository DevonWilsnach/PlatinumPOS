@page "/back-office"
@inject IDbContextFactory<PosDbContext> DbFactory
@inject CashierSession CashierSession
@inject LicenceClientService LicenceService
@inject PosSettingsService Settings
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Back Office — PlatinumPOS</PageTitle>

<div class="pa-6">
    <div class="rw-brand-header mb-6">
        <div class="rw-brand-text">
            <MudText Typo="Typo.h4" Class="mb-1" Style="font-weight: 700; font-family: 'Outfit', sans-serif;">Back Office Management</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Administer products, review sales history, print shift Z-reports, and manage cashier terminal locks.</MudText>
        </div>
    </div>

    <MudTabs Elevation="0" Outlined="true" Rounded="true" Color="Color.Primary" Class="rw-activity-card">
        
        <!-- Tab 1: Sales Dashboard & History -->
        <MudTabPanel Text="Sales Dashboard" Icon="@Icons.Material.Filled.Analytics">
            <div class="pa-4">
                <MudGrid Spacing="3" Class="mb-6">
                    <!-- Revenue Tile -->
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="w8-tile pa-5 d-flex flex-column" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Revenue</MudText>
                            </MudStack>
                            <MudText Typo="Typo.h4" Style="font-weight: 700;">@_currencySymbol@_totalRevenue.ToString("N2")</MudText>
                        </MudPaper>
                    </MudItem>
                    
                    <!-- Sales Count Tile -->
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="w8-tile pa-5 d-flex flex-column" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Transactions</MudText>
                            </MudStack>
                            <MudText Typo="Typo.h4" Style="font-weight: 700;">@_transactions.Count</MudText>
                        </MudPaper>
                    </MudItem>

                    <!-- Avg Sale Tile -->
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="w8-tile pa-5 d-flex flex-column" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Tertiary" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Average Basket Size</MudText>
                            </MudStack>
                            <MudText Typo="Typo.h4" Style="font-weight: 700;">@_currencySymbol@_avgSale.ToString("N2")</MudText>
                        </MudPaper>
                    </MudItem>

                    <!-- Payment Tally Tile -->
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Class="w8-tile pa-5 d-flex flex-column" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Warning" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Cash vs Card Sales</MudText>
                            </MudStack>
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                Cash: @_currencySymbol@_cashTotal.ToString("N2")<br />
                                Card: @_currencySymbol@_cardTotal.ToString("N2")
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <!-- Date Range Filter -->
                <MudPaper Class="pa-4 mb-6 w8-tile" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                    <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="_startDate" Label="Start Date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="_endDate" Label="End Date" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadDataAsync" FullWidth="true" Style="border-radius:100px; font-weight:600;">
                                Apply Filter
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>

                <!-- Daily Z-Report actions -->
                <div class="d-flex justify-between align-center mb-6 pa-4 w8-tile" style="background-color: var(--mud-palette-primary-lighten); border-color: transparent !important;">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary" Style="font-weight:700;">Active Daily Shift Summary</MudText>
                        <MudText Typo="Typo.caption" Style="color: var(--mud-palette-primary-darken)">Generate a POS Z-Report to print and clear current session logs.</MudText>
                    </MudStack>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Style="border-radius:100px; font-weight:600;" 
                               OnClick="PrintZReport" StartIcon="@Icons.Material.Filled.Print">
                        Print Z-Report
                    </MudButton>
                </div>

                <!-- Past transactions table -->
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">Recent Transaction History</MudText>
                <MudTable Items="@_transactions" Hover="true" Breakpoint="Breakpoint.Md" Elevation="0" Dense="true">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>Date/Time</MudTh>
                        <MudTh>Cashier</MudTh>
                        <MudTh>Subtotal</MudTh>
                        <MudTh>Discount</MudTh>
                        <MudTh>Total</MudTh>
                        <MudTh>Method</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh Style="text-align:right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="ID">#@context.Id</MudTd>
                        <MudTd DataLabel="Date/Time">@context.Timestamp.ToLocalTime().ToString("g")</MudTd>
                        <MudTd DataLabel="Cashier">@context.Cashier?.Name</MudTd>
                        <MudTd DataLabel="Subtotal">@_currencySymbol@context.Subtotal.ToString("N2")</MudTd>
                        <MudTd DataLabel="Discount">@_currencySymbol@context.DiscountAmount.ToString("N2")</MudTd>
                        <MudTd DataLabel="Total" Style="font-weight:700;">@_currencySymbol@context.TotalAmount.ToString("N2")</MudTd>
                        <MudTd DataLabel="Method">@context.PaymentMethod</MudTd>
                        <MudTd DataLabel="Status">
                            @if (context.OrderStatus == "Completed")
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Completed</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text">Voided</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align:right">
                            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                                <MudIconButton Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Size="Size.Small" 
                                               OnClick="() => OpenReceiptPreview(context)" title="View Receipt" />
                                @if (context.OrderStatus == "Completed")
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" Style="border-radius:100px;"
                                               OnClick="() => VoidTransactionAsync(context)">
                                        Void
                                    </MudButton>
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </div>
        </MudTabPanel>

        <!-- Tab 2: Products Management -->
        <MudTabPanel Text="Products & Catalog" Icon="@Icons.Material.Filled.RestaurantMenu">
            <div class="pa-4">
                <div class="d-flex justify-between align-center mb-4">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Manage Products</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudFileUpload T="IBrowserFile" FilesChanged="UploadProductsCsvAsync" Accept=".csv">
                            <CustomContent>
                                <MudButton OnClick="@context.OpenFilePickerAsync" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FileUpload" Style="border-radius:100px; font-weight:600;">
                                    Import CSV
                                </MudButton>
                            </CustomContent>
                        </MudFileUpload>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Style="border-radius:100px; font-weight:600;"
                                   OnClick="OpenCreateProductDialog" StartIcon="@Icons.Material.Filled.Add">
                            Add New Product
                        </MudButton>
                    </MudStack>
                </div>

                <MudTable Items="@_products" Hover="true" Breakpoint="Breakpoint.Md" Elevation="0" Dense="true" Filter="FilterProductSearch">
                    <ToolBarContent>
                        <MudTextField @bind-Value="_prodSearch" Placeholder="Search products name or barcode..." Adornment="Adornment.Start" 
                                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Small" Margin="Margin.Dense" 
                                      Variant="Variant.Outlined" Style="max-width:320px;" Immediate="true" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Barcode</MudTh>
                        <MudTh>Product Name</MudTh>
                        <MudTh>Category</MudTh>
                        <MudTh>Selling Price</MudTh>
                        <MudTh>Unit Cost</MudTh>
                        <MudTh>Stock Count</MudTh>
                        <MudTh>Color Theme</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh Style="text-align:right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Barcode" Style="font-family: monospace;">@context.Barcode</MudTd>
                        <MudTd DataLabel="Product Name" Style="font-weight:600">@context.Name</MudTd>
                        <MudTd DataLabel="Category">@context.Category?.Name</MudTd>
                        <MudTd DataLabel="Selling Price">@_currencySymbol@context.Price.ToString("N2")</MudTd>
                        <MudTd DataLabel="Unit Cost">@_currencySymbol@context.Cost.ToString("N2")</MudTd>
                        <MudTd DataLabel="Stock Count">
                            <span class="@(context.StockQuantity <= 5 ? "mud-text-warning font-weight-bold" : "")">
                                @context.StockQuantity
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Color Theme">
                            <span style="@($"display:inline-block; width:12px; height:12px; border-radius:50%; background-color:{context.Color}; margin-right:6px;")"></span>
                            @context.Color
                        </MudTd>
                        <MudTd DataLabel="Status">
                            @if (context.IsActive)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Active</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Text">Inactive</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align:right">
                            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small" 
                                               OnClick="() => OpenEditProductDialog(context)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" 
                                               OnClick="() => DeleteProductAsync(context)" />
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </div>
        </MudTabPanel>

        <!-- Tab: Categories -->
        <MudTabPanel Text="Categories" Icon="@Icons.Material.Filled.Category">
            <div class="pa-4">
                <div class="d-flex justify-between align-center mb-4">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Product Categories</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Style="border-radius:100px; font-weight:600;"
                               OnClick="OpenCreateCategoryDialog" StartIcon="@Icons.Material.Filled.Add">
                        Add New Category
                    </MudButton>
                </div>

                @if (!_categories.Any())
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3" Style="border-radius:12px">
                        No categories yet. Add at least one category here before creating products.
                    </MudAlert>
                }

                <MudTable Items="@_categories" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Dense="true">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>Name</MudTh>
                        <MudTh>Color Theme</MudTh>
                        <MudTh>Products</MudTh>
                        <MudTh Style="text-align:right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>#@context.Id</MudTd>
                        <MudTd Style="font-weight:600">@context.Name</MudTd>
                        <MudTd>
                            <span style="@($"display:inline-block; width:12px; height:12px; border-radius:50%; background-color:{context.Color}; margin-right:6px;")"></span>
                            @context.Color
                        </MudTd>
                        <MudTd>@(_products.Count(p => p.CategoryId == context.Id))</MudTd>
                        <MudTd Style="text-align:right">
                            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small"
                                               OnClick="() => OpenEditCategoryDialog(context)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                               OnClick="() => DeleteCategoryAsync(context)" />
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        </MudTabPanel>

        <!-- Tab 3: Cashier Operators -->
        <MudTabPanel Text="Cashier Profiles" Icon="@Icons.Material.Filled.People">
            <div class="pa-4">
                <div class="d-flex justify-between align-center mb-4">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">Terminal Cashiers</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Style="border-radius:100px; font-weight:600;"
                               OnClick="OpenCreateCashierDialog" StartIcon="@Icons.Material.Filled.PersonAdd">
                        Add New Cashier
                    </MudButton>
                </div>

                <MudTable Items="@_cashiers" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Dense="true">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>Name</MudTh>
                        <MudTh>System Role</MudTh>
                        <MudTh>Active Status</MudTh>
                        <MudTh Style="text-align:right">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>#@context.Id</MudTd>
                        <MudTd Style="font-weight:600">@context.Name</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@(context.Role == "Manager" ? Color.Primary : Color.Default)" Size="Size.Small" Variant="Variant.Filled">
                                @context.Role
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            @if (context.IsActive)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">Active</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text">Disabled</MudChip>
                            }
                        </MudTd>
                        <MudTd Style="text-align:right">
                            <MudStack Row="true" Spacing="1" Justify="Justify.FlexEnd">
                                <MudButton Variant="Variant.Text" Color="Color.Warning" Size="Size.Small" Style="border-radius:100px;"
                                           OnClick="() => OpenResetPinDialog(context)">
                                    Reset PIN
                                </MudButton>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Size="Size.Small" 
                                               OnClick="() => OpenEditCashierDialog(context)" />
                                @if (context.Id != CashierSession.CurrentCashier?.Id)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" 
                                                   OnClick="() => DeleteCashierAsync(context)" />
                                }
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </div>
        </MudTabPanel>

        <!-- Tab 4: System Configurations & Licensing -->
        <MudTabPanel Text="Settings & Licensing" Icon="@Icons.Material.Filled.Settings">
            <div class="pa-4">
                <MudGrid Spacing="4">
                    <!-- Store config section -->
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700;">Store Configurations</MudText>
                        <MudPaper Class="pa-5 w8-tile d-flex flex-column gap-4" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                            <MudTextField @bind-Value="_storeName" Label="Store Display Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudTextField @bind-Value="_currencySymbol" Label="Currency Symbol" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudNumericField @bind-Value="_taxRate" Label="Standard VAT Rate (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Format="F2" />
                            
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" DropShadow="false" Style="border-radius:100px; font-weight:600; mt-2"
                                       OnClick="SaveStoreSettingsAsync">
                                Save Configurations
                            </MudButton>
                        </MudPaper>
                    </MudItem>

                    <!-- License status & sync -->
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700;">Licensing Status</MudText>
                        <MudPaper Class="pa-5 w8-tile d-flex flex-column gap-3" Elevation="0" Style="background-color: var(--mud-palette-surface);">
                            <div class="d-flex justify-between">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Footprint</MudText>
                                <MudText Typo="Typo.body2" Style="font-family: monospace; font-weight:600;">@_footprint</MudText>
                            </div>
                            <div class="d-flex justify-between">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Auth Server</MudText>
                                <MudText Typo="Typo.body2">@_authBaseUrl</MudText>
                            </div>
                            <div class="d-flex justify-between align-center">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">Current Status</MudText>
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.CheckCircle">
                                    Licensed
                                </MudChip>
                            </div>

                            <MudDivider Class="my-2" Style="border-color: var(--mud-palette-divider)" />

                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Style="border-radius:100px; font-weight:600;"
                                       OnClick="CheckLicenseStatusAsync" Disabled="_isCheckingLicense">
                                @if (_isCheckingLicense)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Syncing...</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Small" Class="mr-2" />
                                    <span>Sync with PlatinumAuth</span>
                                }
                            </MudButton>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            </div>
        </MudTabPanel>

        <!-- Tab 5: Audit Logs -->
        <MudTabPanel Text="Audit Logs" Icon="@Icons.Material.Filled.History">
            <div class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">System Activity Logs</MudText>
                <MudTable Items="@_auditLogs" Hover="true" Breakpoint="Breakpoint.Md" Elevation="0" Dense="true" RowsPerPage="20">
                    <HeaderContent>
                        <MudTh>ID</MudTh>
                        <MudTh>Date/Time</MudTh>
                        <MudTh>Cashier/User</MudTh>
                        <MudTh>Action</MudTh>
                        <MudTh>Details</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="ID">#@context.Id</MudTd>
                        <MudTd DataLabel="Date/Time">@context.Timestamp.ToLocalTime().ToString("g")</MudTd>
                        <MudTd DataLabel="User">@context.CashierName</MudTd>
                        <MudTd DataLabel="Action">
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text">@context.Action</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Details">@context.Details</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager />
                    </PagerContent>
                </MudTable>
            </div>
        </MudTabPanel>

    </MudTabs>
</div>

<!-- Receipt Dialog Preview -->
<MudDialog @bind-Visible="_receiptPreviewVisible" Options="_receiptPreviewOptions">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight:700; font-family:'Outfit',sans-serif;">Transaction Details</MudText>
    </TitleContent>
    <DialogContent>
        @if (_viewingTransaction != null)
        {
            <div style="background-color: #FFFFFF; color: #1F1F1F; font-family: 'JetBrains Mono', monospace; border: 1px dashed #747775; padding: 16px; border-radius: 8px; width: 100%; max-width: 320px; font-size: 0.8125rem; margin: 0 auto;">
                <div style="text-align: center; font-weight: bold; font-size: 0.9375rem; margin-bottom: 4px;">
                    @_storeName
                </div>
                <div style="text-align: center; color:#444746; font-size:0.6875rem; margin-bottom: 8px;">
                    Powered by Platinum Brink Technologies
                </div>
                <div style="border-bottom: 1px dashed #E3E3E3; padding-bottom: 4px; margin-bottom: 8px; font-size: 0.6875rem; color:#444746;">
                    Date: @_viewingTransaction.Timestamp.ToLocalTime().ToString("g")<br />
                    Cashier: @_viewingTransaction.Cashier?.Name<br />
                    Sale ID: #@_viewingTransaction.Id<br />
                    Status: @(_viewingTransaction.OrderStatus == "Completed" ? "PAID" : "VOIDED / REFUNDED")
                </div>
                
                @foreach (var item in _viewingItems)
                {
                    <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                        <span>@item.ProductName x @item.Quantity</span>
                        <span>@_currencySymbol@((item.UnitPrice * item.Quantity - item.DiscountAmount).ToString("N2"))</span>
                    </div>
                }
                
                <div style="border-top: 1px dashed #E3E3E3; margin-top:8px; padding-top:8px;">
                    <div style="display: flex; justify-content: space-between; font-weight: bold;">
                        <span>TOTAL</span>
                        <span>@_currencySymbol@_viewingTransaction.TotalAmount.ToString("N2")</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.75rem; margin-top:4px; color:#444746;">
                        <span>Method</span>
                        <span>@_viewingTransaction.PaymentMethod</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color:#444746;">
                        <span>Cash Tendered</span>
                        <span>@_currencySymbol@_viewingTransaction.CashReceived.ToString("N2")</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color:#444746;">
                        <span>Change Given</span>
                        <span>@_currencySymbol@_viewingTransaction.ChangeGiven.ToString("N2")</span>
                    </div>
                </div>
            </div>
        }
    </DialogContent>
