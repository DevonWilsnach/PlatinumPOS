@code {
    // Analytics
    private decimal _totalRevenue;
    private decimal _avgSale;
    private decimal _cashTotal;
    private decimal _cardTotal;

    // Database contents
    private List<Transaction> _transactions = new();
    private List<Product> _products = new();
    private List<Category> _categories = new();
    private List<Cashier> _cashiers = new();
    private List<AuditLog> _auditLogs = new();
    private DateTime? _startDate;
    private DateTime? _endDate;

    // Store settings
    private string _storeName = "Platinum Brink Cafe & Deli";
    private string _currencySymbol = "R";
    private decimal _taxRate = 15m;
    private string _footprint = string.Empty;
    private string _authBaseUrl = string.Empty;

    // Search filters
    private string _prodSearch = string.Empty;

    // Dialog objects
    private bool _receiptPreviewVisible;
    private DialogOptions _receiptPreviewOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private Transaction? _viewingTransaction;
    private List<TransactionItem> _viewingItems = new();

    // Product Dialog Edit variables
    private bool _productDialogVisible;
    private DialogOptions _editDialogOptions = new() { MaxWidth = MaxWidth.Small, FullWidth = true };
    private DialogOptions _smallDialogOptions = new() { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
    private string _productDialogTitle = string.Empty;
    private Product _editingProduct = new();
    private bool _isCreatingProduct = false;

    // Category Dialog variables
    private bool _categoryDialogVisible;
    private string _categoryDialogTitle = string.Empty;
    private Category _editingCategory = new();
    private bool _isCreatingCategory = false;

    // Cashier Dialog Edit variables
    private bool _cashierDialogVisible;
    private string _cashierDialogTitle = string.Empty;
    private Cashier _editingCashier = new();
    private bool _isCreatingCashier = false;
    private string _newCashierPin = string.Empty;

    // Reset pin dialog
    private bool _resetPinDialogVisible;

    private bool _isCheckingLicense = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        
        var query = db.Transactions.Include(t => t.Cashier).AsQueryable();
        if (_startDate.HasValue)
            query = query.Where(t => t.Timestamp >= _startDate.Value.ToUniversalTime());
        if (_endDate.HasValue)
            query = query.Where(t => t.Timestamp <= _endDate.Value.AddDays(1).AddTicks(-1).ToUniversalTime());
            
        _transactions = await query.OrderByDescending(t => t.Timestamp).ToListAsync();
        _products = await db.Products.Include(p => p.Category).ToListAsync();
        _categories = await db.Categories.ToListAsync();
        _cashiers = await db.Cashiers.ToListAsync();
        _auditLogs = await db.AuditLogs.OrderByDescending(a => a.Timestamp).ToListAsync();

        _storeName = await Settings.GetStoreNameAsync();
        _currencySymbol = await Settings.GetCurrencySymbolAsync();
        _taxRate = await Settings.GetTaxRateAsync();
        _footprint = await LicenceService.GetFootprintAsync();
        _authBaseUrl = await LicenceService.GetAuthBaseUrlAsync();

        CalculateAnalytics();
    }

    private void CalculateAnalytics()
    {
        var completed = _transactions.Where(t => t.OrderStatus == "Completed").ToList();
        
        _totalRevenue = completed.Sum(t => t.TotalAmount);
        _avgSale = completed.Any() ? completed.Average(t => t.TotalAmount) : 0m;
        
        _cashTotal = completed.Where(t => t.PaymentMethod == "Cash").Sum(t => t.TotalAmount);
        _cardTotal = completed.Where(t => t.PaymentMethod == "Card").Sum(t => t.TotalAmount);
    }

    private bool FilterProductSearch(Product element) => 
        string.IsNullOrWhiteSpace(_prodSearch) ||
        element.Name.Contains(_prodSearch, StringComparison.OrdinalIgnoreCase) ||
        element.Barcode.Contains(_prodSearch, StringComparison.OrdinalIgnoreCase);

    private async Task OpenReceiptPreview(Transaction tr)
    {
        _viewingTransaction = tr;
        using var db = await DbFactory.CreateDbContextAsync();
        _viewingItems = await db.TransactionItems.Where(ti => ti.TransactionId == tr.Id).ToListAsync();
        _receiptPreviewVisible = true;
    }

    private async Task VoidTransactionAsync(Transaction tr)
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var dbTr = await db.Transactions.FirstOrDefaultAsync(t => t.Id == tr.Id);
            if (dbTr == null) return;

            dbTr.OrderStatus = "Voided";
            db.Transactions.Update(dbTr);

            // Re-increment stock levels
            var items = await db.TransactionItems.Where(ti => ti.TransactionId == tr.Id).ToListAsync();
            foreach (var item in items)
            {
                if (item.ProductId.HasValue)
                {
                    var prod = await db.Products.FirstOrDefaultAsync(p => p.Id == item.ProductId.Value);
                    if (prod != null)
                    {
                        prod.StockQuantity += item.Quantity;
                        db.Products.Update(prod);
                    }
                }
            }

            await db.SaveChangesAsync();
            Snackbar.Add($"Transaction #{tr.Id} has been voided. Stock returned.", Severity.Warning);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Void failed: {ex.Message}", Severity.Error);
        }
    }

    private void PrintZReport()
    {
        var totalSales = _transactions.Where(t => t.OrderStatus == "Completed").Sum(t => t.TotalAmount);
        var cashSales = _transactions.Where(t => t.OrderStatus == "Completed" && t.PaymentMethod == "Cash").Sum(t => t.TotalAmount);
        var cardSales = _transactions.Where(t => t.OrderStatus == "Completed" && t.PaymentMethod == "Card").Sum(t => t.TotalAmount);
        var count = _transactions.Where(t => t.OrderStatus == "Completed").Count();
        var voided = _transactions.Where(t => t.OrderStatus == "Voided").Count();

        Snackbar.Add($"Z-Report printed! Shift totals cleared.", Severity.Info);
        // Print Z-Report log mockup, then optionally clear transactions
    }

    private void OpenCreateProductDialog()
    {
        if (!_categories.Any())
        {
            Snackbar.Add("Add a category first (Categories tab) before creating products.", Severity.Warning);
            return;
        }
        _editingProduct = new Product { IsActive = true, StockQuantity = 0, Color = "#CD853F", CategoryId = _categories.First().Id };
        _isCreatingProduct = true;
        _productDialogTitle = "Add New Product";
        _productDialogVisible = true;
    }

    private async Task UploadProductsCsvAsync(IBrowserFile file)
    {
        if (file == null) return;
        
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10485760); // 10MB max
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();
            var lines = content.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
            
            if (lines.Length <= 1)
            {
                Snackbar.Add("CSV file is empty or only contains a header.", Severity.Warning);
                return;
            }

            var headers = lines[0].Split(',');
            using var db = await DbFactory.CreateDbContextAsync();
            int importedCount = 0;

            for (int i = 1; i < lines.Length; i++)
            {
                var cols = lines[i].Split(',');
                if (cols.Length < 3) continue;

                var barcode = cols[0].Trim();
                var name = cols[1].Trim();
                var catIdStr = cols[2].Trim();
                var priceStr = cols.Length > 3 ? cols[3].Trim() : "0";
                var costStr = cols.Length > 4 ? cols[4].Trim() : "0";
                var stockStr = cols.Length > 5 ? cols[5].Trim() : "0";

                int.TryParse(catIdStr, out var catId);
                decimal.TryParse(priceStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var price);
                decimal.TryParse(costStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var cost);
                int.TryParse(stockStr, out var stock);

                // Skip if category doesn't exist
                if (!await db.Categories.AnyAsync(c => c.Id == catId)) continue;

                var existingProduct = await db.Products.FirstOrDefaultAsync(p => p.Barcode == barcode);
                if (existingProduct != null)
                {
                    existingProduct.Name = name;
                    existingProduct.CategoryId = catId;
                    existingProduct.Price = price;
                    existingProduct.Cost = cost;
                    existingProduct.StockQuantity = stock;
                    db.Products.Update(existingProduct);
                }
                else
                {
                    db.Products.Add(new Product
                    {
                        Barcode = barcode,
                        Name = name,
                        CategoryId = catId,
                        Price = price,
                        Cost = cost,
                        StockQuantity = stock,
                        IsActive = true,
                        Color = "Default"
                    });
                }
                importedCount++;
            }
            
            db.AuditLogs.Add(new AuditLog
            {
                Timestamp = DateTime.UtcNow,
                CashierName = CashierSession.CurrentCashier?.Name ?? "System",
                Action = "CSV Import",
                Details = $"Imported/Updated {importedCount} products via CSV."
            });

            await db.SaveChangesAsync();
            Snackbar.Add($"Successfully imported/updated {importedCount} products.", Severity.Success);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error importing CSV: {ex.Message}", Severity.Error);
        }
    }

    private void OpenEditProductDialog(Product prod)
    {
        _editingProduct = new Product
        {
            Id = prod.Id,
            Name = prod.Name,
            CategoryId = prod.CategoryId,
            Price = prod.Price,
            Cost = prod.Cost,
            StockQuantity = prod.StockQuantity,
            Barcode = prod.Barcode,
            Color = prod.Color,
            IsActive = prod.IsActive
        };
        _isCreatingProduct = false;
        _productDialogTitle = $"Edit {prod.Name}";
        _productDialogVisible = true;
    }

    private async Task SaveProductAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingProduct.Name) || string.IsNullOrWhiteSpace(_editingProduct.Barcode))
        {
            Snackbar.Add("Name and Barcode are required.", Severity.Warning);
            return;
        }

        if (_editingProduct.CategoryId <= 0 || !_categories.Any(c => c.Id == _editingProduct.CategoryId))
        {
            Snackbar.Add("Please select a valid category.", Severity.Warning);
            return;
        }

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            if (_isCreatingProduct)
            {
                db.Products.Add(_editingProduct);
            }
            else
            {
                db.Products.Update(_editingProduct);
            }

            await db.SaveChangesAsync();
            Snackbar.Add("Product saved successfully.", Severity.Success);
            _productDialogVisible = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteProductAsync(Product prod)
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            db.Products.Remove(prod);
            await db.SaveChangesAsync();
            Snackbar.Add($"{prod.Name} deleted.", Severity.Warning);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    // Category actions
    private void OpenCreateCategoryDialog()
    {
        _editingCategory = new Category { Color = "#2563EB", Icon = "Category" };
        _isCreatingCategory = true;
        _categoryDialogTitle = "Add New Category";
        _categoryDialogVisible = true;
    }

    private void OpenEditCategoryDialog(Category cat)
    {
        _editingCategory = new Category { Id = cat.Id, Name = cat.Name, Color = cat.Color, Icon = cat.Icon };
        _isCreatingCategory = false;
        _categoryDialogTitle = $"Edit {cat.Name}";
        _categoryDialogVisible = true;
    }

    private async Task SaveCategoryAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingCategory.Name))
        {
            Snackbar.Add("Category name is required.", Severity.Warning);
            return;
        }

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            if (_isCreatingCategory)
            {
                db.Categories.Add(_editingCategory);
            }
            else
            {
                db.Categories.Update(_editingCategory);
            }

            await db.SaveChangesAsync();
            Snackbar.Add("Category saved successfully.", Severity.Success);
            _categoryDialogVisible = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteCategoryAsync(Category cat)
    {
        if (_products.Any(p => p.CategoryId == cat.Id))
        {
            Snackbar.Add($"Cannot delete '{cat.Name}' — it still has products. Reassign or delete those products first.", Severity.Warning);
            return;
        }

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var dbCat = await db.Categories.FirstOrDefaultAsync(c => c.Id == cat.Id);
            if (dbCat != null)
            {
                db.Categories.Remove(dbCat);
                await db.SaveChangesAsync();
            }
            Snackbar.Add($"Category '{cat.Name}' deleted.", Severity.Warning);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    // Cashier actions
    private void OpenCreateCashierDialog()
    {
        _editingCashier = new Cashier { Role = "Cashier" };
        _newCashierPin = string.Empty;
        _isCreatingCashier = true;
        _cashierDialogTitle = "Add New Cashier Profile";
        _cashierDialogVisible = true;
    }

    private void OpenEditCashierDialog(Cashier cash)
    {
        _editingCashier = new Cashier
        {
            Id = cash.Id,
            Name = cash.Name,
            Role = cash.Role,
            PinHash = cash.PinHash,
            IsActive = cash.IsActive
        };
        _isCreatingCashier = false;
        _cashierDialogTitle = $"Edit {cash.Name}";
        _cashierDialogVisible = true;
    }

    private async Task SaveCashierAsync()
    {
        if (string.IsNullOrWhiteSpace(_editingCashier.Name))
        {
            Snackbar.Add("Cashier name is required.", Severity.Warning);
            return;
        }

        if (_isCreatingCashier && (_newCashierPin.Length != 4 || !int.TryParse(_newCashierPin, out _)))
        {
            Snackbar.Add("PIN code must be exactly 4 numeric digits.", Severity.Warning);
            return;
        }

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            
            if (_isCreatingCashier)
            {
                var hashedPin = SecurityHelper.HashPin(_newCashierPin);
                if (await db.Cashiers.AnyAsync(c => c.PinHash == hashedPin))
                {
                    Snackbar.Add("PIN is already in use by another cashier. Please choose a different PIN.", Severity.Error);
                    return;
                }
                
                _editingCashier.PinHash = hashedPin;
                db.Cashiers.Add(_editingCashier);
            }
            else
            {
                db.Cashiers.Update(_editingCashier);
            }

            await db.SaveChangesAsync();
            Snackbar.Add("Cashier saved successfully.", Severity.Success);
            _cashierDialogVisible = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private void OpenResetPinDialog(Cashier cash)
    {
        _editingCashier = cash;
        _newCashierPin = string.Empty;
        _resetPinDialogVisible = true;
    }

    private async Task SaveResetPinAsync()
    {
        if (_editingCashier == null) return;
        if (_newCashierPin.Length != 4 || !int.TryParse(_newCashierPin, out _))
        {
            Snackbar.Add("PIN code must be exactly 4 numeric digits.", Severity.Warning);
            return;
        }

        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            var hashedPin = SecurityHelper.HashPin(_newCashierPin);
            
            if (await db.Cashiers.AnyAsync(c => c.PinHash == hashedPin && c.Id != _editingCashier.Id))
            {
                Snackbar.Add("PIN is already in use by another cashier. Please choose a different PIN.", Severity.Error);
                return;
            }

            var dbCash = await db.Cashiers.FirstOrDefaultAsync(c => c.Id == _editingCashier.Id);
            if (dbCash != null)
            {
                dbCash.PinHash = hashedPin;
                db.Cashiers.Update(dbCash);
                await db.SaveChangesAsync();
                Snackbar.Add($"PIN for {dbCash.Name} updated successfully.", Severity.Success);
            }
            _resetPinDialogVisible = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"PIN reset failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteCashierAsync(Cashier cash)
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            db.Cashiers.Remove(cash);
            await db.SaveChangesAsync();
            Snackbar.Add($"Cashier {cash.Name} removed.", Severity.Warning);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    // Save configurations
    private async Task SaveStoreSettingsAsync()
    {
        await Settings.SetSettingAsync("StoreName", _storeName);
        await Settings.SetSettingAsync("CurrencySymbol", _currencySymbol);
        await Settings.SetSettingAsync("TaxRate", _taxRate.ToString());
        
        Snackbar.Add("System settings updated.", Severity.Success);
        await LoadDataAsync();
    }

    // Sync license
    private async Task CheckLicenseStatusAsync()
    {
        _isCheckingLicense = true;
        try
        {
            var success = await LicenceService.RefreshAsync();
            if (success)
            {
                var status = await LicenceService.GetStatusAsync();
                if (status.IsLicensed)
                {
                    Snackbar.Add("License synced. Active and valid.", Severity.Success);
                }
                else
                {
                    Snackbar.Add("License synced. Expired or disabled. Contact administrator.", Severity.Warning);
                    Nav.NavigateTo("licence-check");
                }
            }
            else
            {
                Snackbar.Add("Failed to reach PlatinumAuth licensing server.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCheckingLicense = false;
            await LoadDataAsync();
        }
    }
}
